__pycache__/
*.pyc
*.pyo
.DS_Store

# Backend pytest suite (tests/python/)
.venv/
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/

# tests/panel (Playwright)
tests/panel/node_modules/
tests/panel/test-results/
# ...and the stray root-level dir Playwright creates when run from the
