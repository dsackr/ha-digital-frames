/test-results/
tests/panel/playwright-report/
tests/panel/blob-report/
tests/panel/playwright/.cache/

# Local network captures (contain auth tokens) — never commit
scratchpad-capture/
*.har

# HA long-lived access token(s) — never commit
ha.cred
*.cred
